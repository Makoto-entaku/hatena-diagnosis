'use client';

import { useSearchParams } from 'next/navigation';
import type { ResultResponse } from '@/lib/types';
import ScoreRadar from './ScoreRadar';
import TypeIllustration from './TypeIllustration';
import PrintButton from './PrintButton';

const AXIS_ORDER = [
  { id: 'social',    label: '社交度',     left: 'ひとり派',    right: '社交的',      leftShort: 'ひとり派', rightShort: '社交的' },
  { id: 'tolerance', label: '心の広さ度', left: 'シビア',      right: '寛容',        leftShort: 'シビア',   rightShort: '寛容' },
  { id: 'action',    label: '怠惰度',     left: 'シャキシャキ', right: 'ぐうたら',   leftShort: 'シャキ',   rightShort: 'ぐうたら' },
  { id: 'self',      label: '自分大切度', left: '他人優先',    right: '自分優先',    leftShort: '他人優先', rightShort: '自分優先' },
  { id: 'logical',   label: 'ロジカル度', left: '感情派',      right: 'ロジカル派',  leftShort: '感情派',   rightShort: 'ロジカル' },
];

function getAxisLabel(axisId: string, score: number): string {
  const axis = AXIS_ORDER.find(a => a.id === axisId);
  if (!axis) return '';
  return score >= 50 ? axis.right : axis.left;
}

export default function ResultCard({ result }: { result: ResultResponse }) {
  const searchParams = useSearchParams();
  const station = Number(searchParams.get('station') ?? '1');

  return (
    <article className="mx-auto w-full max-w-2xl px-3 py-3 print:px-2 print:py-2 print:max-w-none bg-white">

      {/* 大タイトル */}
      <div className="text-center mb-2">
        <h1 className="text-2xl font-black text-navy leading-tight">
          はてな展 診断結果？？？
        </h1>
        <p className="text-xs text-navy/60 mt-0.5">20の質問から見えた、あなたの&ldquo;めんどくさい傾向&rdquo;</p>
      </div>

      {/* タイプブロック */}
      <section className="rounded-2xl bg-navy px-5 py-4 text-white print-keep-color print:rounded-none flex items-center gap-4 mb-3">
        <div className="flex-1">
          <div className="text-[10px] font-bold tracking-widest opacity-60 mb-1">TYPE {result.type_code}</div>
          <h2 className="text-2xl font-black leading-tight">{result.type_name}</h2>
          <p className="text-xs opacity-80 mt-1">{result.tagline}</p>
          <p className="text-xs opacity-90 mt-2 leading-relaxed">{result.description}</p>
        </div>
        <div className="shrink-0">
          <TypeIllustration typeId={result.type_id} typeName={result.type_name} size={110} />
        </div>
      </section>

      {/* 5軸スコア */}
      <section className="rounded-2xl bg-white border border-gray-100 px-4 py-3 mb-3 print:rounded-none print:border-0">
        <h3 className="text-sm font-bold text-navy mb-2 text-center">5つの尺度でみるあなたの傾向</h3>
        <div className="flex gap-3 items-center">
          <div className="shrink-0">
            <ScoreRadar scores={result.display_scores} size={170} />
          </div>
          <div className="flex-1">
            {AXIS_ORDER.map(axis => {
              const score = result.scores[axis.id] ?? 50;
              const displayScore = result.display_scores[axis.label] ?? score;
              const label = getAxisLabel(axis.id, score);
              const diff = result.axis_comparisons[axis.id] ?? 0;
              const positive = diff > 0;
              const neutral = diff === 0;
              return (
                <div key={axis.id} className="flex items-center gap-1.5 py-1 border-b border-gray-50 last:border-0">
                  <span className="text-[10px] text-navy/50 w-16 shrink-0">{axis.label}</span>
                  <span className="text-base font-black text-navy w-8 text-right shrink-0">{Math.round(displayScore)}</span>
                  <span className="text-[10px] text-navy/70 w-14 shrink-0">{label}寄り</span>
                  <span className={`text-[10px] font-bold shrink-0 ${neutral ? 'text-navy/40' : positive ? 'text-emerald-600' : 'text-rose-600'}`}>
                    {diff > 0 ? '+' : ''}{diff.toFixed(1)}
                  </span>
                  <span className="text-[9px] text-navy/30 shrink-0">全体50</span>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      {/* ちょっと変だった回答 */}
      {result.weird_answers && result.weird_answers.length > 0 && (
        <section className="rounded-2xl bg-navy/5 px-4 py-3 mb-3 print:rounded-none print-keep-color">
          <h3 className="text-sm font-bold text-navy mb-2">🔍 ちょっと変だった回答</h3>
          <ul className="flex flex-col gap-1.5">
            {result.weird_answers.map((w, i) => (
              <li key={i} className="flex items-baseline gap-1.5 text-xs">
                <span className="shrink-0 text-navy">●</span>
                <span className="flex-1 text-navy/80">{w.question_summary}</span>
                <span className="shrink-0 font-bold text-navy">→ {w.answer_label}</span>
                <span className="shrink-0 text-navy/50">（全体の{w.ratio}%）</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {/* 基本傾向 + 対人運アップ 横並び */}
      <div className="grid grid-cols-2 gap-3 mb-3">
        <section className="rounded-2xl bg-white border border-gray-100 px-4 py-3 print:rounded-none print:border-0">
          <h3 className="text-xs font-black text-navy mb-1">A 基本傾向</h3>
          <p className="text-xs leading-relaxed text-navy/80">{result.tendency}</p>
        </section>
        <section className="rounded-2xl bg-white border border-gray-100 px-4 py-3 print:rounded-none print:border-0">
          <h3 className="text-xs font-black text-navy mb-1">D 対人運アップのひとこと</h3>
          <p className="text-xs leading-relaxed text-navy/80">{result.advice}</p>
        </section>
      </div>

      {/* フッター */}
      <footer className="text-center border-t border-gray-100 pt-2">
        <p className="text-xs font-bold text-navy">はてな展 @ 西武渋谷店　2026.6.26 FRI — 9.30 TUE</p>
      </footer>

      {/* 印刷ボタン（画面のみ） */}
      <div className="mt-5 flex justify-center print-hidden">
        <PrintButton resultId={result.result_id} station={station} />
      </div>
      <p className="print-hidden mt-3 text-center text-[10px] text-navy/30">
        result_id: {result.result_id}
      </p>

    </article>
  );
}
